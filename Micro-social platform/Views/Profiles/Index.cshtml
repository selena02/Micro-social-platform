<h2>See all profiles</h2>
<a class="btn btn-info mt-3 mb-3 " href ="/Profiles/New">Create a Profile</a>

@foreach (var profile in ViewBag.Profiles)
{
    <div class="card" >
        <div class="card-body">
            <div class="d-flex flex-row mt-5" style="gap:30px">
            <img style="width:150px" src="@profile.ProfilePicture" class="card-img-top">
                <h3 class="card-title py-3 px-3 rounded-2"><i class="bi bi-person-fill"></i>@profile.UserName</h3>
            </div>
            <div class="card-text">@profile.Description</div>
            <span>@profile.IsPrivate</span>
            <div class="d-flex flex-row justify-content-between mt-5 ">
                
                <a class="btn btn-outline-info" href="/Profiles/Show/@profile.ProfileId">See profile</a>
           </div>
        </div>
    </div>
    <br />
    <br />
}